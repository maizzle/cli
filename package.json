{
  "name": "@maizzle/cli",
  "version": "3.0.0-rc.0",
  "description": "CLI tool for the Maizzle Email Framework",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "dev": "vitest",
    "test": "vitest run --coverage",
    "release": "npm run build && npx np"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "create-maizzle": "^1.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maizzle/cli.git"
  },
  "bugs": "https://github.com/maizzle/cli/issues",
  "homepage": "https://maizzle.com",
  "author": "Cosmin Popovici (https://github.com/cossssmin)",
  "keywords": [
    "maizzle",
    "tailwindcss",
    "responsive-email",
    "email-framework",
    "email-template",
    "email-marketing",
    "email-campaigns",
    "email-newsletter",
    "email-boilerplate",
    "html-emails",
    "email-cli"
  ]
}
